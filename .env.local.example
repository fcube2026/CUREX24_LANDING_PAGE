# Supabase – copy this file to .env.local and fill in your values
# Get these from: https://supabase.com/dashboard → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# URL of the deployed questionnaire Vite app (Vercel Project 2)
# Set this in Vercel dashboard → Project 1 (landing) → Settings → Environment Variables
QUESTIONNAIRE_URL=https://curex24-questionnaire.vercel.app
