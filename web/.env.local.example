# Supabase – copy this file to .env.local and fill in your values
# Get these from: https://supabase.com/dashboard → your project → Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Supabase Edge Function URL (for form submission)
VITE_FUNCTION_URL=https://your-project-id.supabase.co/functions/v1/your-function-name

# Shared secret used to authenticate form submissions to the Edge Function
VITE_FORM_SHARED_SECRET=your-shared-secret-here
